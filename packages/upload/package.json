{
  "name": "@bunny.net/upload",
  "publishConfig": { "access": "public" },
  "version": "0.0.0",
  "description": "Drop-in file uploads for Bunny Storage — client engine + server handler",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@bunny.net/upload-core": "workspace:*",
    "@bunny.net/upload-handler": "workspace:*",
    "@bunny.net/upload-shared": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.5.0"
  },
  "keywords": [
    "bunny",
    "upload",
    "storage",
    "cdn",
    "file-upload"
  ],
  "license": "MIT"
}
